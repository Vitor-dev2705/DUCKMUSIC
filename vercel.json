{
  "builds": [
    { "src": "index.php", "use": "vercel-php@0.7.2" },
    { "src": "app.php", "use": "vercel-php@0.7.2" },
    { "src": "terms.php", "use": "vercel-php@0.7.2" },
    { "src": "api/**/*.php", "use": "vercel-php@0.7.2" },
    { "src": "auth/**/*.php", "use": "vercel-php@0.7.2" },
    { "src": "paginas/**/*.php", "use": "vercel-php@0.7.2" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/app", "dest": "/app.php" },
    { "src": "/", "dest": "/index.php" },
    { "src": "/(.*\\.php)", "dest": "/$1" }
  ]
}
